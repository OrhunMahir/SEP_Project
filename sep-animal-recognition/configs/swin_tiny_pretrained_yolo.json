{
  "experiment_name": "swin_tiny_pretrained_yolo",
  "seed": 42,
  "model": {
    "name": "swin_tiny",
    "num_outputs": 21,
    "dropout": 0.1,
    "attention_dropout": 0.0,
    "pretrained": true,
    "weights": "IMAGENET1K_V1",
    "trainable_backbone": "last_stage"
  },
  "data": {
    "image_size": 224,
    "batch_size": 16,
    "num_workers": 4,
    "train_split": "splits/train_seed42.csv",
    "validation_split": "splits/val_seed42.csv"
  },
  "training": {
    "max_epochs": 30,
    "warmup_epochs": 5,
    "learning_rate": 0.0005,
    "weight_decay": 0.0001,
    "label_smoothing": 0.1,
    "early_stopping_patience": 30
  },
  "postprocessing": {
    "confidence_threshold": 0.54
  },
  "yolo": {
    "model": "yolov8n.pt",
    "confidence_threshold": 0.25,
    "allowed_classes": ["cat", "dog"],
    "crop_padding": 0.10,
    "selection": "largest_area"
  },
  "output_dir": "runs/swin_tiny_pretrained_yolo"
}
