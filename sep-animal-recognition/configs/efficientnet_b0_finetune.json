{
  "experiment_name": "efficientnet_b0_finetune",
  "seed": 42,
  "model": {
    "name": "efficientnet_b0",
    "num_outputs": 21,
    "dropout": 0.2,
    "pretrained": true
  },
  "data": {
    "image_size": 224,
    "batch_size": 32,
    "num_workers": 4,
    "train_split": "splits/train_seed42.csv",
    "validation_split": "splits/val_seed42.csv"
  },
  "training": {
    "max_epochs": 30,
    "warmup_epochs": 2,
    "learning_rate": 0.0001,
    "weight_decay": 0.0001,
    "label_smoothing": 0.1,
    "selection_metric": "accuracy",
    "early_stopping_patience": 8
  },
  "output_dir": "runs/efficientnet_b0_finetune"
}
