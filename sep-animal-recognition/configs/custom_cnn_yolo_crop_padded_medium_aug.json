{
  "experiment_name": "custom_cnn_yolo_crop_padded_medium_aug",
  "seed": 42,
  "model": {
    "name": "custom_cnn_8conv",
    "num_outputs": 21,
    "dropout": 0.3
  },
  "data": {
    "image_size": 224,
    "batch_size": 32,
    "num_workers": 4,
    "train_split": "splits/train_seed42.csv",
    "validation_split": "splits/val_seed42.csv",
    "image_root": "runs/custom_cnn_yolo_crop_padded_medium_aug/yolo_crops"
  },
  "augmentation": {
    "random_resized_crop_scale": [0.65, 1.0],
    "crop_aspect_ratio": [0.80, 1.25],
    "horizontal_flip_probability": 0.5,
    "rotation_degrees": 15,
    "color_jitter_probability": 0.7,
    "brightness": 0.25,
    "contrast": 0.25,
    "saturation": 0.20,
    "hue": 0.03,
    "random_grayscale_probability": 0.05,
    "random_perspective_probability": 0.10,
    "perspective_distortion": 0.10,
    "random_erasing_probability": 0.10,
    "erasing_scale": [0.02, 0.10]
  },
  "training": {
    "max_epochs": 50,
    "warmup_epochs": 5,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "label_smoothing": 0.1,
    "early_stopping_patience": 10
  },
  "output_dir": "runs/custom_cnn_yolo_crop_padded_medium_aug"
}
