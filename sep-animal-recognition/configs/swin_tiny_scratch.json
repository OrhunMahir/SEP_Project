{
  "experiment_name": "swin_tiny_scratch",
  "seed": 42,
  "model": {
    "name": "swin_tiny",
    "num_outputs": 21,
    "dropout": 0.1,
    "attention_dropout": 0.0
  },
  "data": {
    "image_size": 224,
    "batch_size": 16,
    "num_workers": 4,
    "train_split": "splits/train_seed42.csv",
    "validation_split": "splits/val_seed42.csv"
  },
  "training": {
    "max_epochs": 50,
    "warmup_epochs": 5,
    "learning_rate": 0.0005,
    "weight_decay": 0.01,
    "label_smoothing": 0.1,
    "early_stopping_patience": 50
  },
  "output_dir": "runs/swin_tiny_scratch"
}
