{
  "experiment_name": "custom_cnn_8conv_strong_aug_scratch",
  "seed": 42,
  "model": {
    "name": "custom_cnn_8conv",
    "num_outputs": 21,
    "dropout": 0.3
  },
  "augmentation": {
    "random_resized_crop_scale": [0.55, 1.0],
    "random_resized_crop_ratio": [0.75, 1.33],
    "horizontal_flip_probability": 0.5,
    "rotation_degrees": 25,
    "color_jitter_probability": 0.8,
    "brightness": 0.35,
    "contrast": 0.35,
    "saturation": 0.30,
    "hue": 0.05,
    "random_grayscale_probability": 0.10,
    "random_perspective_probability": 0.25,
    "random_perspective_distortion": 0.20,
    "random_erasing_probability": 0.25,
    "random_erasing_scale": [0.02, 0.15],
    "random_erasing_ratio": [0.3, 3.3]
  },
  "data": {
    "image_size": 224,
    "batch_size": 32,
    "num_workers": 4,
    "train_split": "splits/train_seed42.csv",
    "validation_split": "splits/val_seed42.csv"
  },
  "training": {
    "max_epochs": 50,
    "warmup_epochs": 5,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "label_smoothing": 0.1,
    "early_stopping_patience": 10,
    "selection_metric": "macro_f1"
  },
  "output_dir": "runs/custom_cnn_8conv_strong_aug_scratch"
}
