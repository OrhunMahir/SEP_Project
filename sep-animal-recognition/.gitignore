.DS_Store
**/.DS_Store
__pycache__/
*.py[cod]
.venv/

# Large training artifacts stay on local or cluster storage, not in Git.
*.pt
runs/**
runs/*/history.json
runs/*/summary.json
runs/*/config.json
slurm_logs/*.out
slurm_logs/*.err
!slurm_logs/.gitkeep
docs/gradcam_outputs/**/*.out
docs/gradcam_outputs/**/*.err
